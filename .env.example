# ==============================================================================
# Minimal Vercel Setup (Required for Core Browsing/Streaming)
# ==============================================================================

# Required: Generate a strong random string.
# Example: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_KEY="YOUR_RANDOM_FLASK_SECRET_KEY"

# Required: Must match Miruro-API API_KEY if your Miruro API enforces x-api-key.
API_KEY="YOUR_GENERATED_API_KEY"

# Required: Base URL for your deployed Miruro-compatible API.
MIRURO_API_URL="https://api.your-domain.com/"

# Recommended: Base URL for your M3U8 proxy to bypass CORS on stream links.
# If omitted, app falls back to an internal default proxy.
PROXY_URL="https://proxy.your-domain.com/proxy/"


# ==============================================================================
# Optional: API Origin Controls
# ==============================================================================
# Used as Origin header toward Miruro API requests.
ALLOWED_ORIGINS="https://your-app.app,http://localhost:5000"


# ==============================================================================
# Optional Feature Flags
# ==============================================================================
# If omitted, features auto-enable only when required env vars exist.
# Set explicitly to true/false to force behavior.
ENABLE_AUTH="false"
ENABLE_WATCHLIST="false"
ENABLE_TURNSTILE="false"
ENABLE_EMAIL_RESET="false"
ENABLE_ANILIST="false"
ENABLE_MAL="false"


# ==============================================================================
# Optional: MongoDB (Required for local accounts/watchlist/settings persistence)
# ==============================================================================
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=YourApp"
db="name_of_your_database"
users_collection="name_of_your_users_collection"
watchlist_collection="name_of_your_watchlist_collection"
comments_collection="comments"
episode_reactions_collection="episode_reactions"


# ==============================================================================
# Optional: Cloudflare Turnstile (Captcha)
# ==============================================================================
CLOUDFLARE_SECRET="YOUR_CLOUDFLARE_SECRET"
CF_SITE_KEY="YOUR_CF_SITE_KEY"


# ==============================================================================
# Optional: Gmail SMTP (Password Reset Emails)
# ==============================================================================
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"


# ==============================================================================
# Optional: AniList OAuth
# ==============================================================================
ANILIST_CLIENT_ID="YOUR_ANILIST_CLIENT_ID"
ANILIST_CLIENT_SECRET="YOUR_ANILIST_CLIENT_SECRET"
ANILIST_REDIRECT_URI="https://your-domain.com/auth/anilist/callback"


# ==============================================================================
# Optional: MyAnimeList OAuth
# ==============================================================================
MAL_CLIENT_ID="YOUR_MAL_CLIENT_ID"
MAL_CLIENT_SECRET="YOUR_MAL_CLIENT_SECRET"
MAL_REDIRECT_URI="https://your-domain.com/auth/mal/callback"


# ==============================================================================
# Optional: Geo Routing For Default Watch Server
# ==============================================================================
# API key used for IP-to-country fallback lookup in watch routing.
IPGEOLOCATION_API_KEY=""
# Countries that should default to internal Arc/HLS server (ISO2 CSV).
GEO_DEFAULT_INTERNAL_COUNTRIES="US,GB,CA,AU"